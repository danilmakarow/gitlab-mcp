{
  "name": "gitlab-mcp",
  "version": "0.1.0",
  "description": "Model Context Protocol server exposing GitLab actions (projects, branches, commits, merge requests, pipelines, notes) to AI agents.",
  "author": "Danil Makarov <https://t.me/dnmkr>",
  "private": true,
  "license": "UNLICENSED",
  "scripts": {
    "build": "nest build",
    "format": "prettier --write \"src/**/*.ts\"",
    "start": "nest start",
    "start:dev": "nest start --watch",
    "start:debug": "nest start --debug --watch",
    "start:prod": "node dist/main",
    "lint": "eslint \"src/**/*.ts\"",
    "type": "tsc --noEmit"
  },
  "dependencies": {
    "@modelcontextprotocol/sdk": "^1.0.4",
    "@nestjs/common": "^11.0.1",
    "@nestjs/config": "^4.0.2",
