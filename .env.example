NODE_ENV=development
PORT=3000

# Public URL of this MCP server (no trailing slash). For Vercel this is the project URL.
PUBLIC_BASE_URL=http://localhost:3000

# GitLab API — outbound credentials.
GITLAB_BASE_URL=https://gitlab.com
GITLAB_TOKEN=glpat-xxxxxxxxxxxxxxxxxxxx
GITLAB_TIMEOUT_MS=30000

# GitHub OAuth app (https://github.com/settings/developers).
# Callback URL to register at GitHub: <PUBLIC_BASE_URL>/auth/callback
GITHUB_CLIENT_ID=
GITHUB_CLIENT_SECRET=

# Comma-separated GitHub usernames allowed to connect this MCP server.
GITHUB_USERNAMES_ALLOWLIST=danil,coworker1,coworker2

# 32+ byte random string — signs access tokens issued to MCP clients.
# Generate with: node -e "console.log(require('crypto').randomBytes(48).toString('base64url'))"
JWT_SECRET=
